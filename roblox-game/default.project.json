{
  "name": "MiningCorporation",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "Config": {
        "$path": "src/shared/Config"
      },
      "Shared": {
        "$className": "Folder"
      },
      "Assets": {
        "$className": "Folder"
      }
    },

    "ServerScriptService": {
      "Bootstrap": {
        "$path": "src/server/Bootstrap.server.luau"
      },
      "DevCommands": {
        "$path": "src/server/DevCommands.server.luau"
      },
      "Services": {
        "$path": "src/server/Services"
      },
      "Systems": {
        "$className": "Folder"
      },
      "Data": {
        "$path": "src/server/Data"
      }
    },

    "StarterPlayer": {
      "StarterPlayerScripts": {
        "Controllers": {
          "$path": "src/client/Controllers"
        }
      }
    },

    "Workspace": {
      "$properties": {
        "FilteringEnabled": true
      },
      "Baseplate": {
        "$className": "Part",
        "$properties": {
          "Anchored": true,
          "Color": [0.38823, 0.37254, 0.38823],
          "Locked": true,
          "Position": [0, -10, 0],
          "Size": [512, 20, 512]
        }
      }
    },
    "Lighting": {
      "$properties": {
        "Ambient": [0, 0, 0],
        "Brightness": 2,
        "GlobalShadows": true,
        "Outlines": false,
        "Technology": "Voxel"
      }
    },
    "SoundService": {
      "$properties": {
        "RespectFilteringEnabled": true
      }
    }
  }
}
